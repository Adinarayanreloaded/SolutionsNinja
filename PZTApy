from sys import stdin

def pushZerosAtEnd(arr, n):
    # Initialize the index for the next non-zero element
    nonZeroIndex = 0

    # Traverse the array
    for i in range(n):
        if arr[i] != 0:
            # If the current element is non-zero, place it at the nonZeroIndex
            arr[nonZeroIndex] = arr[i]
            # Increment the nonZeroIndex
            nonZeroIndex += 1
    
    # Fill the remaining positions with zeros
    while nonZeroIndex < n:
        arr[nonZeroIndex] = 0
        nonZeroIndex += 1

#Taking Input Using Fast I/O
def takeInput() :
    n = int(stdin.readline().rstrip())

    if n == 0:
        return list(), 0
    
    arr = list(map(int, stdin.readline().rstrip().split()))
    return arr, n
  

#to print the array/list
def printList(arr, n) : 
    for i in range(n) :
        print(arr[i], end = " ")

    print()


#main
t = int(stdin.readline().strip())

while t > 0 :

    arr, n = takeInput()

    pushZerosAtEnd(arr, n)
    printList(arr, n)

    t -= 1